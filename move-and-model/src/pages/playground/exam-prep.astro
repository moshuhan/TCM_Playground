<style>
  .stub-page {
    padding: 80px 24px 120px;
    text-align: center;
  }
  h1 {
    font-size: 22px;
    margin-bottom: 12px;
  }
  .lead {
    font-size: 14px;
    color: var(--color-muted);
  }
  .lead a {
    text-decoration: underline;
  }
</style>
